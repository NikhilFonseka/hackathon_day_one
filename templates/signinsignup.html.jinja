<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portal - Profile</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>
<body>

    <nav class="navbar">
        <div class="logo">Student Portal</div>

        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/calendar">Events</a></li>
            <li><a href="/upload">Upload</a></li>
            <li><a href="/profile">Profile</a></li>
        </ul>
    </nav>
    
    <main>
        {% if session.get('user_name') %}
            
            <section style="text-align: center;">
                <h2>Welcome back, {{ session.get('user_name') }}!</h2>
                
                {% if session.get('profile_image') %}
                    <img src="{{ url_for('static', filename='uploads/' + session.get('profile_image')) }}" 
                         alt="Profile Picture" 
                         style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; margin: 20px 0;">
                {% endif %}
                
                <br>
                <hr>
                
                <section style="text-align: left; margin-bottom: 2rem;">
                    <h2>My Friends</h2>
                    <div class="friends-container">
                        {% for friend in friends %}
                            <div class="friend-display">
                                <p>{{ friend['name'] }}</p>
                            </div>
                        {% else %}
                            <p style="color: var(--ink-muted);">You haven't added any friends yet.</p>
                        {% endfor %}
                    </div>
                </section>

                <section style="text-align: left; margin-bottom: 2rem;">
                    <h2>Pending Friend Requests</h2>
                    {% for req in pending_reqs %}
                        <div style="border: 1px solid #ccc; border-radius: 5px; padding: 1rem; margin-bottom: 1rem; background-color: #f9f9f9;">
                            <p>Friend request from: <strong>{{ req['sender_name'] }}</strong></p>
                            
                            <form action="/handle_request/{{ req['interactionid'] }}" method="POST" style="display: inline-block;">
                                <input type="hidden" name="action" value="accepted">
                                <button type="submit" style="padding: 0.5rem 1rem; font-size: 0.9rem; cursor: pointer;">Accept</button>
                            </form>
                            
                            <form action="/handle_request/{{ req['interactionid'] }}" method="POST" style="display: inline-block;">
                                <input type="hidden" name="action" value="rejected">
                                <button type="submit" style="padding: 0.5rem 1rem; font-size: 0.9rem; border-color: #dc3545; color: #dc3545; background: none; cursor: pointer;">Reject</button>
                            </form>
                        </div>
                    {% else %}
                        <p style="color: gray;">No pending friend requests.</p>
                    {% endfor %}
                </section>

                <section style="text-align: left; margin-bottom: 2rem;">
                    <h2>Add a Friend</h2>
                    <form action="/send_request" method="POST">
                        <div style="margin-bottom: 1rem;">
                            <label for="friend_email">Student Email:</label>
                            <input type="email" id="friend_email" name="friend_email" required placeholder="student@school.edu" style="width: 100%; padding: 0.5rem; margin-top: 0.5rem;">
                        </div>
                        <button type="submit" style="width: 100%; padding: 0.75rem; cursor: pointer;">Send Friend Request</button>
                    </form>
                </section>
                
                <hr>
                <a href="/logout"><button style="padding: 0.5rem 1rem; cursor: pointer;">Log Out</button></a>
            </section>

        {% else %}
            
            <section>
                <h2>Student Sign Up</h2>
                <form action="/signup" method="POST" enctype="multipart/form-data">
                    
                    <div style="margin-bottom: 1rem;">
                        <label for="reg_name">Full Name:</label>
                        <input type="text" id="reg_name" name="name" required style="width: 100%; padding: 0.5rem; margin-top: 0.5rem;">
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label for="reg_email">Email:</label>
                        <input type="email" id="reg_email" name="email" required style="width: 100%; padding: 0.5rem; margin-top: 0.5rem;">
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label for="reg_password">Password:</label>
                        <input type="password" id="reg_password" name="password" required style="width: 100%; padding: 0.5rem; margin-top: 0.5rem;">
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label for="reg_image">Profile Image:</label>
                        <input type="file" id="reg_image" name="profile_image" accept="image/*" required style="margin-top: 0.5rem;">
                    </div>

                    <button type="submit" style="width: 100%; padding: 0.75rem; cursor: pointer;">Sign Up</button>
                </form>
            </section>

            <hr>

            <section>
                <h2>Student Sign In</h2>
                <form action="/signin" method="POST">
                    
                    <div style="margin-bottom: 1rem;">
                        <label for="login_email">Email:</label>
                        <input type="email" id="login_email" name="email" required style="width: 100%; padding: 0.5rem; margin-top: 0.5rem;">
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label for="login_password">Password:</label>
                        <input type="password" id="login_password" name="password" required style="width: 100%; padding: 0.5rem; margin-top: 0.5rem;">
                    </div>

                    {% if error %}
                        <div style="color: #dc3545; background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 5px; padding: 0.75rem; margin-bottom: 1rem; text-align: center;">
                            {{ error }}
                        </div>
                    {% endif %}

                    <button type="submit" style="width: 100%; padding: 0.75rem; cursor: pointer;">Sign In</button>
                </form>
            </section>  
        
        {% endif %}

</body>
</html>