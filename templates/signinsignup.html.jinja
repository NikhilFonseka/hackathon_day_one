<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portal - Profile</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>
<body>

    <nav class="navbar">
        <div class="logo">ROBCO OS v3.0</div>

        <ul class="nav-links">
            <li><a href="/">HOME</a></li>
            <li><a href="/calendar">EVENTS</a></li>
            <li><a href="/upload">UPLOAD</a></li>
            <li><a href="/profile">PROFILE</a></li>
        </ul>
    </nav>
    
    <main>
        {% if session.get('user_name') %}
            
            <section style="text-align: center;">
                <h2>Welcome back, {{ session.get('user_name') }}!</h2>
                
                {% if session.get('profile_image') %}
                    <img src="{{ url_for('static', filename='uploads/' + session.get('profile_image')) }}" 
                         alt="Profile Picture" 
                         style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; margin: 20px 0;">
                {% endif %}
                
                <br>
                <hr>
                
                <section style="text-align: left; margin-bottom: 2rem;">
                    <h2>[ ESTABLISHED ALLIES ]</h2>
                    <ul>
                        {% for friend in friends %}
                            <li>> {{ friend['name'] }} [STATUS: ONLINE]</li>
                        {% else %}
                            <li>[ NO ALLIES FOUND IN LOCAL NETWORK ]</li>
                        {% endfor %}
                    </ul>
                </section>

                <section style="text-align: left; margin-bottom: 2rem;">
                    <h2>[ PENDING UPLINK REQUESTS ]</h2>
                    {% for req in pending_reqs %}
                        <div style="border: 1px dashed var(--primary-dim); padding: 1rem; margin-bottom: 1rem;">
                            <p>INCOMING TRANSMISSION FROM: <strong>{{ req['sender_name'] }}</strong></p>
                            
                            <form action="/handle_request/{{ req['interactionid'] }}" method="POST" style="display: inline-block;">
                                <input type="hidden" name="action" value="accepted">
                                <button type="submit" style="padding: 0.5rem 1rem; font-size: 0.8rem;">[ ACCEPT ]</button>
                            </form>
                            
                            <form action="/handle_request/{{ req['interactionid'] }}" method="POST" style="display: inline-block;">
                                <input type="hidden" name="action" value="rejected">
                                <button type="submit" style="padding: 0.5rem 1rem; font-size: 0.8rem; border-color: #8B0000; color: #8B0000;">[ REJECT ]</button>
                            </form>
                        </div>
                    {% else %}
                        <p>[ NO INCOMING TRANSMISSIONS ]</p>
                    {% endfor %}
                </section>

                <section style="text-align: left; margin-bottom: 2rem;">
                    <h2>[ INITIATE NEW CONNECTION ]</h2>
                    <form action="/send_request" method="POST">
                        <div>
                            <label for="friend_email">TARGET COURIER EMAIL:</label>
                            <input type="email" id="friend_email" name="friend_email" required placeholder="user@robco.net">
                        </div>
                        <button type="submit" style="width: 100%;">[ TRANSMIT FRIEND REQUEST ]</button>
                    </form>
                </section>
                
                <hr>
                <a href="/logout"><button>Log Out</button></a>
            </section>

        {% else %}

            <div style="text-align: center; margin-bottom: 2rem;">
                <img src="https://upload.wikimedia.org/wikipedia/en/6/61/Vault_Boy_artwork.png" 
                     class="vault-mascot" 
                     alt="Vault-Tec Approved">
                <p style="font-size: 0.8rem; letter-spacing: 2px; margin-top: 0.5rem;">[VAULT-TEC OS V3.0.1 - READY]</p>
            </div>
            
            <section>
                <h2>Student Sign Up</h2>
                <form action="/signup" method="POST" enctype="multipart/form-data">
                    
                    <div>
                        <label for="reg_name">Full Name:</label>
                        <input type="text" id="reg_name" name="name" required>
                    </div>

                    <div>
                        <label for="reg_email">Email:</label>
                        <input type="email" id="reg_email" name="email" required>
                    </div>

                    <div>
                        <label for="reg_password">Password:</label>
                        <input type="password" id="reg_password" name="password" required>
                    </div>

                    <div>
                        <label for="reg_image">Profile Image:</label>
                        <input type="file" id="reg_image" name="profile_image" accept="image/*" required>
                    </div>

                    <button type="submit">Sign Up</button>
                </form>
            </section>

            <hr>

            <section>
                <h2>Student Sign In</h2>
                <form action="/signin" method="POST">
                    
                    <div>
                        <label for="login_email">Email:</label>
                        <input type="email" id="login_email" name="email" required>
                    </div>

                    <div>
                        <label for="login_password">Password:</label>
                        <input type="password" id="login_password" name="password" required>
                    </div>

                    {% if error %}
                        <div style="color: #ff3333; border: 1px dashed #ff3333; padding: 0.5rem; margin-bottom: 1rem; text-align: center; text-shadow: 0 0 5px #ff3333;">
                            {{ error }}
                        </div>
                    {% endif %}

                    <button type="submit">Sign In</button>
                </form>
            </section>
            
        {% endif %}
    </main>

</body>
</html>