<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portal - Home</title>
    
    <!-- CSS -->
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">Student Portal</div>

        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/calendar">Events</a></li>
            <li><a href="/upload">Upload</a></li>
            <li><a href="/profile">Profile</a></li>
        </ul>
    </nav>
    
    <!-- MAIN CONTENT -->
    <main class="container" style="padding: 2rem; max-width: 1200px; margin: 0 auto; text-align: center;">
        
        <!-- Welcome Hero Section -->
        <header style="margin-bottom: 3rem; padding: 2rem 0;">
            {% if session.get('user_name') %}
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: #333;">Welcome back, {{ session.get('user_name') }}!</h1>
            {% else %}
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: #333;">Welcome to the Student Portal</h1>
            {% endif %}
            <p style="font-size: 1.2rem; color: #666; max-width: 600px; margin: 0 auto;">
                Your central hub for building school spirit. Discover upcoming events, share your favorite campus moments, and connect with your classmates.
            </p>
        </header>

        <!-- Navigation Dashboard -->
        <section style="display: flex; flex-wrap: wrap; gap: 2rem; justify-content: center;">
            
            <!-- Events Card -->
            <div style="flex: 1 1 300px; padding: 2rem; border: 1px solid #e0e0e0; border-radius: 8px; background-color: #ffffff; text-align: left; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <h2 style="margin-top: 0; color: #2c3e50; font-size: 1.5rem;">📅 Campus Events</h2>
                <p style="color: #555; margin-bottom: 1.5rem; line-height: 1.5;">
                    Break out of your routine! See what events are coming up, find out where your friends are heading, and discover new clubs and activities.
                </p>
                <a href="/calendar" style="display: inline-block; padding: 0.6rem 1.2rem; background-color: #0056b3; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">View Calendar</a>
            </div>

            <!-- Profile Card -->
            <div style="flex: 1 1 300px; padding: 2rem; border: 1px solid #e0e0e0; border-radius: 8px; background-color: #ffffff; text-align: left; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <h2 style="margin-top: 0; color: #2c3e50; font-size: 1.5rem;">🤝 Connect</h2>
                <p style="color: #555; margin-bottom: 1.5rem; line-height: 1.5;">
                    Grow your network on campus. Add new friends, accept connection requests, and manage your student profile settings.
                </p>
                <a href="/profile" style="display: inline-block; padding: 0.6rem 1.2rem; background-color: #0056b3; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">Go to Profile</a>
            </div>

        </section>
    </main>

    <!-- FOOTER -->
    <footer class="footer" style="text-align: center; padding: 2rem; margin-top: 3rem; border-top: 1px solid #eaeaea; color: #888;">
        <p>© 2026 Student Portal</p>
    </footer>

</body>
</html>