<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Events Feed</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>

<body>

<!-- Top Navbar -->
<div class="navbar">
  <h2>Events</h2>
</div>

<!-- Feed -->
<div class="feed">

  {% for event in events %}
  <div class="post">

    <!-- Post Header -->
    <div class="post-header">
      <h3>{{ event['name'] }}</h3>

      <span class="badge {% if not event['house_points'] %}off{% endif %}">
        {% if event['house_points'] %}
          House Points
        {% else %}
          No House Points
        {% endif %}
      </span>
    </div>

    <!-- Image -->
    {% if event['image'] %}
      <img 
        src="{{ url_for('static', filename='uploads/' + event['image']) }}" 
        class="post-image"
      >
    {% else %}
      <div class="post-image placeholder"></div>
    {% endif %}

    <!-- Body -->
    <div class="post-body">
      <p class="time">
        📅 {{ event['event_date'] }} • ⏰ {{ event['event_time'] }}
      </p>
    </div>

  </div>
  {% endfor %}

</div>

</body>
</html>