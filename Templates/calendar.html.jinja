<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Events Feed - RobCo Terminal</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>

<body>

    <nav class="navbar">
        <div class="logo">ROBCO OS v3.0</div>

        <ul class="nav-links">
            <li><a href="/">HOME</a></li>
            <li><a href="/calendar">EVENTS</a></li>
            <li><a href="/upload">UPLOAD</a></li>
            <li><a href="/profile">PROFILE</a></li>
        </ul>
    </nav>

    <main class="container">
        <h2>[EVENT FEED // UPLINK SECURED]</h2>
        
        <div class="feed">
            {% for event in events %}
            <div class="post">

                <div class="post-header">
                    <h3>{{ event['name'] }}</h3>

                    {% if event['event_id'] in recommended_ids %}
                        <div style="background-color: var(--primary-color); color: var(--bg-color); font-weight: bold; padding: 0.3rem; text-align: center; font-size: 0.8rem; margin-bottom: 0.5rem; letter-spacing: 2px;">
                            [ OVERSEER AI RECOMMENDATION ]
                        </div>
                    {% endif %}

                    <span class="badge {% if not event['house_points'] %}off{% endif %}">
                        {% if event['house_points'] %}
                            [+ HOUSE POINTS]
                        {% else %}
                            [- NO POINTS]
                        {% endif %}
                    </span>
                </div>

                {% if event['image'] %}
                    <img src="{{ url_for('static', filename='uploads/' + event['image']) }}" class="post-image">
                {% else %}
                    <div class="post-image placeholder">NO VISUAL DATA</div>
                {% endif %}

                <div class="post-body">
                    <p class="time">
                        DATE: {{ event['event_date'] }} <br>
                        TIME: {{ event['event_time'] }}
                    </p>
                    
                    <div style="margin-top: 1rem;">
                        {% if session.get('user_id') %}
                            {% if event['event_id'] in interested_ids %}
                                <button disabled style="width: 100%; padding: 0.5rem; font-size: 0.85rem; border-color: var(--primary-dim); color: var(--primary-dim); cursor: not-allowed;">
                                    [ ALREADY TRACKING ]
                                </button>
                            {% else %}
                                <form action="/interested/{{ event['event_id'] }}" method="POST">
                                    <button type="submit" style="width: 100%; padding: 0.5rem; font-size: 0.85rem;">
                                        [ MARK INTERESTED ]
                                    </button>
                                </form>
                            {% endif %}
                        {% else %}
                            <p style="font-size: 0.8rem; color: var(--primary-dim); text-align: center;">[ LOG IN TO TRACK EVENTS ]</p>
                        {% endif %}
                    </div>
                    {% if session.get('user_id') %}
                        <div style="margin-top: 1rem; font-size: 0.8rem; border-top: 1px dashed var(--primary-dim); padding-top: 0.5rem;">
                            {% if friends_attending.get(event['event_id']) %}
                                <p style="color: var(--primary-color); margin-bottom: 0;">
                                    > ALLIES DEPLOYING: 
                                    {% for friend in friends_attending[event['event_id']] %}
                                        <strong>{{ friend }}</strong>{% if not loop.last %}, {% endif %}
                                    {% endfor %}
                                </p>
                            {% else %}
                                <p style="color: var(--primary-dim); margin-bottom: 0;">> NO KNOWN ALLIES TRACKING THIS CONTRACT.</p>
                            {% endif %}
                        </div>
                    {% endif %}

                </div>

            </div>
            {% else %}
                <p>[NO EVENTS FOUND IN DATABANKS]</p>
            {% endfor %}
        </div>
    </main>

</body>
</html>